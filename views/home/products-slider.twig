<div id="block{{ id }}" data-block-id="{{ id }}">
    {% if title %}        
    <div class="text-center mb-5 section_title">
        <h3 class="display-4 text-black bg-transparent">{{ title }}</h3>
        <p class="section-description">
        {{ content['settings']['producrs_description'] }} 
        </p>
    </div>
    {% endif %}
    
 
    <div id="slider{{ id }}" class="home-grid mb-20 owl-carousel owl-theme">
        {% for product in products %}
           
            <div class="product-box px-0">
                <div>
                    {% if product['new'] %}
                        <div class="sticker new">
                            {{ ('shop::app.products.new'|trans) }}
                        </div>
                    {% endif %}

                    <a href="/{{ product['url_key'] }}" title="{{ product['name'] }}" class="product-a">
                        <div class="product-image">
                            <img src="{{ product.product.base_image_url }}" alt="{{product['name']}}" loading="lazy"/>
                            {% if product['promotion_title'] %}
                                <div class="card-promo">{{ product['promotion_title'] }}</div>
                            {% endif %}
                        </div>
                        <div class="product-information w-100 mt-4">
                            <div class="product-name">
                                <p class="text-center">{{ product['name'] }}</p>
                            </div>
                        </div>
                    </a>

                    <div class="product-bottom-row">
                        {{ product.html_price | raw }}
                    </div>

                    <div class="hover-buttons">
                        {% include 'shop::products/wishlist.twig' %}
                        
                        <form id="addToCart-{{ product.product_id }}">
                            <input type="hidden" name="_token" value="{{ csrf_token() }}">
                            <input type="hidden" name="product_id" value="{{ product.product_id }}">
                            <input type="hidden" name="quantity" value="1">
                            
                            {% set outOfStock = getConfig('config.products.out-of-stock') == '1' %}

                            {% if outOfStock and not product.saleable %}
                                <span class="not-available">{{ ('shop::app.products.out_of_stock'|trans) }}</span>
                            {% else %}
                                <button type="button" class="btn addToCart border-0" {{ product.saleable ? '' : 'disabled' }} data-id="{{ product.product_id }}">
                                    <i class="icon-cart"></i>
                                </button>
                            {% endif %}
                        </form>
                    </div>
                </div>
            </div>
            
        {% endfor %}
        
       
    </div>
    
    
   
</div>


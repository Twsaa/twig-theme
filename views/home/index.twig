                        delay: 1000,
                    },
                    navigation: {
                        nextEl: ".s-slider-next",
                        prevEl: ".s-slider-prev",
                    },
                });
            });
    </script>
    <script>
        $('.owl-carousel').hide();
        $('.product-group').hide();
        setTimeout(() => {
            $('.product-slider').owlCarousel({
                loop: false,
                autoplay: true,
                autoplayTimeout: 5000,
                autoWidth: true,
                rewind: true,
                margin: 15,
                nav: true,
                rtl: {{ lang ? 'true' : 'false' }},
            });

            setTimeout(() => {
                $('.product-group-arrow-prev').click(function() {
                    $('.owl-prev').click();
                })

                $('.product-group-arrow-next').click(function() {
                    $(' .owl-next').click();
                })
            }, 1000);

            $('.product-group').slideDown();
            $('.owl-carousel').fadeIn();
        }, 3000);
    </script>
    <script>
    $(document).ready(function () {
    $('.load-products').each(function () {
        let block = $(this);
        
        // 1. Capture the variables from the data-attributes of the current block
        let blockId = block.data('id');
        let blockType = block.data('type');
        let blockLimit = block.data('limit');

        // 2. Perform the AJAX call
        $.ajax({
            url: '/fetch-home-products', 
            method: 'GET',
            data: {
                id: blockId,    // Using the variable we just defined
                type: blockType,
                limit: blockLimit
            },
            success: function (response) {
                // Inject the HTML fragment from Twig
                block.html(response);

                // 3. Initialize Owl Carousel if it's a slider
                if (blockType === 'slider') {
                    let sliderSelector = $('#slider' + blockId);
                    
                    if ($.fn.owlCarousel) {
                        sliderSelector.owlCarousel({
                            loop: false,
                            autoplay: true,
                            autoplayTimeout: 4000,
                            autoWidth: true,
                            margin: 15,
                            nav: false,
                            rtl: {{ lang ? 'true' : 'false' }}
                        });
                    }
                }
            },
            error: function (xhr, status, error) {
                console.error("AJAX Error: " + error);
            }
        });
        });
    });
    </script>
{% endblock %}

    